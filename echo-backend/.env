# AWS Configuration
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_DEFAULT_REGION=us-east-1

# Nova Model IDs
NOVA_LITE_MODEL_ID=apac.amazon.nova-lite-v1:0
NOVA_LITE_REGION=ap-south-1
NOVA_PRO_MODEL_ID=apac.amazon.nova-pro-v1:0
NOVA_MICRO_MODEL_ID=apac.amazon.nova-micro-v1:0

# Nova Sonic
NOVA_SONIC_MODEL_ID=amazon.nova-2-sonic-v1:0
NOVA_SONIC_REGION=us-east-1

# Embeddings
NOVA_EMBEDDINGS_MODEL_ID=amazon.titan-embed-text-v2:0
EMBEDDINGS_REGION=ap-south-1

# Nova Act
NOVA_ACT_API_KEY=

# App Config
APP_NAME=Echo Legal AI
DEBUG=true

OPENSEARCH_ENDPOINT=https://xxx.us-east-1.aoss.amazonaws.com
OPENSEARCH_REGION=us-east-1